generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HabitFrequency {
  DAILY
  WEEKLY
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  weeklyEmailEnabled Boolean  @default(true)
  dailyEmailEnabled  Boolean  @default(true)
  dailyPushEnabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  notes     Notes[]
  habits    Habit[]  // Relation vers les habitudes
  emailDispatchLogs EmailDispatchLog[]
  dailyEmailDispatchLogs DailyEmailDispatchLog[]
  pushSubscriptions PushSubscription[]
  dailyPushDispatchLogs DailyPushDispatchLog[]
}

model Habit {
  id          String                @id @default(uuid())
  title       String
  emoji       String                @default("🎯")
  targetValue Int                   @default(1)
  frequency   HabitFrequency        @default(DAILY)
  activeDays  Int[]                 @default([1, 2, 3, 4, 5, 6, 7])
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  
  // Relation avec l'utilisateur
  userId      String
  user        User                  @relation(fields: [userId], references: [clerkId])
  
  // Relation avec les completions
  completions HabitCompletion[]

  @@index([userId]) // Pour accélérer la recherche des habitudes d'un user précis
}

model HabitCompletion {
  id        String   @id @default(uuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  value     Int      @default(1)
  completedDate DateTime // Date de completion (sans l'heure)
  createdAt DateTime @default(now())

  @@unique([habitId, completedDate]) // Une completion par habit par jour
  @@index([habitId])
}

model Notes {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId])
}

model EmailDispatchLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  weekStartDate  DateTime
  status         String   @default("SENT")
  sentAt         DateTime @default(now())

  @@unique([userId, weekStartDate])
  @@index([weekStartDate])
}

model DailyEmailDispatchLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  dispatchDate DateTime
  status       String   @default("SENT")
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@unique([userId, dispatchDate])
  @@index([dispatchDate])
}

model PushSubscription {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  endpoint      String   @unique
  p256dh        String
  auth          String
  expirationTime DateTime?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureReason String?

  @@index([userId])
}

model DailyPushDispatchLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  dispatchDate DateTime
  status       String   @default("SENT")
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@unique([userId, dispatchDate])
  @@index([dispatchDate])
}
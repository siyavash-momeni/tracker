# --- Clerk ---
CLERK_WEBHOOK_SIGNING_SECRET=
# Vérifie la signature des webhooks Clerk côté serveur.
CLERK_SECRET_KEY=
# Clé privée serveur Clerk pour l'authentification backend.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clé publique Clerk utilisée côté frontend.

# --- Base de données ---
DATABASE_URL=
# URL de connexion PostgreSQL utilisée par Prisma.

# --- Email hebdomadaire ---
CRON_WEEKLY_EMAIL_SECRET=
# Secret d'auth du cron d'email hebdomadaire.
EMAIL_FROM=
# Adresse expéditrice des emails transactionnels.
RESEND_API_KEY=
# Clé API Resend pour envoyer les emails.

# --- Email quotidien IA ---
CRON_DAILY_AI_EMAIL_SECRET=
# Secret d'auth du cron d'email quotidien IA.
OPENAI_API_KEY=
# Clé API OpenAI pour générer le contenu IA quotidien.
SHOW_EMAIL_TEST_ACTIONS=
# Active les actions de test d'envoi email dans les settings.

# --- Notifications Push ---
CRON_DAILY_PUSH_SECRET=
# Secret d'auth du cron de notifications push quotidiennes.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Clé publique VAPID utilisée par le navigateur pour l'abonnement push.
VAPID_PRIVATE_KEY=
# Clé privée VAPID utilisée serveur pour envoyer les pushes.
VAPID_SUBJECT=
# Contact associé aux clés VAPID (format mailto:).
